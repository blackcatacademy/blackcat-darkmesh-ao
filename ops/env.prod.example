# Production-ready baseline (strict mode)

AUTH_REQUIRE_SIGNATURE=1
AUTH_SIGNATURE_TYPE=ed25519
# Path to ed25519 public key (PEM or raw depending on backend)
AUTH_SIGNATURE_PUBLIC=/etc/ao/keys/ed25519.pub
# Record the pubkey checksum (sha256) in ops notes and rotate keys regularly.
# Example: sha256sum /etc/ao/keys/ed25519.pub
AUTH_ALLOW_SHELL_FALLBACK=0

# Persistent rate limiting
AUTH_RATE_LIMIT_SQLITE=/var/lib/ao/rate.db
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=200

# Metrics
METRICS_ENABLED=1
METRICS_PROM_PATH=/var/lib/ao/metrics.prom
METRICS_FLUSH_INTERVAL_SEC=10

# Arweave HTTP
ARWEAVE_HTTP_MAX_BODY=1048576
ARWEAVE_MAX_MANIFEST_BYTES=262144
ARWEAVE_RESPONSE_PATTERN=^\\s*\\{

# Optional: require cjson is installed (already hard dependency for responses)

# Audit
AUDIT_LOG_DIR=/var/log/ao/audit
AUDIT_ROTATE_MAX=1048576
AUDIT_RETAIN_FILES=10

# Schema manifest (Arweave)
SCHEMA_MANIFEST_TX=iygsD6GhCXGI1cXrl2lw6VOpxbjwISZO5pqWmo7y8XM
SCHEMA_HASH=b1ee8a00d4d2c989c4d7a88daf1ca45c0ea70fb0037dd8b688d44d05f9f534d5
