{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product",
  "type": "object",
  "required": ["sku", "name"],
  "properties": {
    "sku": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"},
    "name": {"type": "string", "minLength": 1, "maxLength": 256},
    "description": {"type": "string", "maxLength": 4000},
    "price": {"type": "number", "minimum": 0},
    "currency": {"type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"]},
    "vatRate": {"type": "number", "minimum": 0, "maximum": 1},
    "taxClass": {"type": "string", "minLength": 1, "maxLength": 64},
    "assets": {"type": "array", "items": {"type": "string", "pattern": "^[A-Za-z0-9._/-]+$"}, "minItems": 0}
  },
  "additionalProperties": false
}
