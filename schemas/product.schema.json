{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product",
  "type": "object",
  "required": ["sku", "name"],
  "properties": {
    "sku": {"type": "string"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "price": {"type": "number"},
    "assets": {"type": "array", "items": {"type": "string"}}
  }
}
