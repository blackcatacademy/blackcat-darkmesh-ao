{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entitlement",
  "type": "object",
  "required": ["subject", "asset"],
  "properties": {
    "subject": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"},
    "asset": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[A-Za-z0-9._/:#-]+$"},
    "policy": {"type": "string", "maxLength": 256}
  },
  "additionalProperties": false
}
