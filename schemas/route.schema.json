{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Route",
  "type": "object",
  "required": ["siteId", "path", "pageId"],
  "properties": {
    "siteId": {"type": "string", "minLength": 1, "maxLength": 128},
    "path": {"type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^/.*"},
    "locale": {"type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$"},
    "pageId": {"type": "string", "minLength": 1, "maxLength": 128},
    "type": {"type": "string", "enum": ["page", "redirect", "asset"]}
  }
}
