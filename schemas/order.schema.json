{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Order",
  "type": "object",
  "required": ["orderId", "siteId", "status"],
  "properties": {
    "orderId": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"},
    "siteId": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"},
    "status": {"type": "string", "enum": ["created", "paid", "shipped", "delivered", "cancelled", "refunded"]},
    "totalAmount": {"type": "number", "minimum": 0},
    "currency": {"type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"]},
    "vatRate": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string", "maxLength": 512}
  },
  "additionalProperties": false
}
